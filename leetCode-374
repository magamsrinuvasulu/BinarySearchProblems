public class Solution extends GuessGame {
    public int guessNumber(int n) {
        int start=1,end=n;
        while(start<=end){
            int pick=start+(end-start)/2;
            int value=guess(pick);
            if(value==0){
                return pick;
            }else if(value==-1){
                end=pick-1;
            }else{
                start=pick+1;
            }
        }
        return -2;
    }
}
