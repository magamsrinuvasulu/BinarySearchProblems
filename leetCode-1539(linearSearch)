class Solution {
    public static boolean linearSearch(int[] nums,int target){
        for(int i=0;i<nums.length;i++){
            if(nums[i]==target){
                return true;
            }
        }
        return false;
    }
    public int findKthPositive(int[] arr, int k) {
        int target=0;
        while(k>0){
            target++;
        if(!linearSearch(arr,target)){
            k--;
        }
        }
        return target;
    }

}
