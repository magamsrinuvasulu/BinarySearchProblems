class Solution {
    public static boolean linearSearch(int[] nums,int target){
        int start=0;
        int end=nums.length-1;
        while(start<=end){
            int mid=start+(end-start)/2;
            if(nums[mid]==target){
                return true;
            }else if(target>nums[mid]){
            start=mid+1;
        }else{
            end=mid-1;
        }
    }
        return false;
    }
    public int findKthPositive(int[] arr, int k) {
        int target=0;
        while(k>0){
            target++;
        if(!linearSearch(arr,target)){
            k--;
        }
        }
        return target;
    }

}
